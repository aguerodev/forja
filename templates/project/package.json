{
  "name": "{{APP}}",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "biome check . && prettier --check \"**/*.tsx\" && tsc --noEmit && depcruise src && vitest run --project unit && pnpm check:migrations && pnpm audit --audit-level=high",
    "fix": "biome check --write . && prettier --write \"**/*.tsx\"",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:mutation": "stryker run --incremental",
    "test:contract": "schemathesis run --experimental=openapi-3.1 --base-url http://localhost:3000 --hypothesis-max-examples 25 openapi.json",
    "check:migrations": "node scripts/lint-migrations.mjs src/core/db/migrations",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "8.5.0",
    "drizzle-orm": "0.45.2",
    "next": "15.5.20",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testcontainers/postgresql": "12.0.4",
    "@types/node": "22.20.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "3.2.6",
    "dependency-cruiser": "18.0.0",
    "drizzle-kit": "0.31.10",
    "fast-check": "4.8.0",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  },
  "engines": {
    "node": ">={{NODE_VERSION}}",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
