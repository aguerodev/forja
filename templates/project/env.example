# Dev fallbacks for src/core/config.ts. Copy to .env (gitignored) and fill in.
# Contract (doctrine wiki ops/07): the secret name IS the Zod field name. In
# prod every field is a file /run/secrets/<field> (Docker secret); in local
# dev the fallback is the UPPERCASED env var, loaded from .env.

# DB_URL=postgres://{{DB_USER}}:{{DB_USER}}@localhost:5432/{{DB_NAME}}
# SESSION_SECRET=<generate one: openssl rand -hex 32>
# APP_BASE_URL=http://localhost:3000

# drizzle-kit (pnpm db:generate / db:migrate) reads DATABASE_URL, not DB_URL:
# DATABASE_URL=postgres://{{DB_USER}}:{{DB_USER}}@localhost:5432/{{DB_NAME}}
